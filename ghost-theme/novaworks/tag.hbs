{{!< default}}

<section class="container">
    <header class="page-head">
        <span class="page-head-kicker">Tag</span>
        {{#tag}}
            <h1 class="page-head-title">{{name}}</h1>
            {{#if description}}<p class="page-head-desc">{{description}}</p>{{/if}}
        {{/tag}}
    </header>

    {{#if posts}}
        <div class="post-grid">
            {{#foreach posts}}
                {{> post-card}}
            {{/foreach}}
        </div>
        {{pagination}}
    {{else}}
        <p class="empty-state">No posts under this tag yet.</p>
    {{/if}}
</section>
