{{!< default}}

<section class="container">
    <header class="page-head">
        <span class="page-head-kicker">Author</span>
        {{#author}}
            <h1 class="page-head-title">{{name}}</h1>
            {{#if bio}}<p class="page-head-desc">{{bio}}</p>{{/if}}
        {{/author}}
    </header>

    {{#if posts}}
        <div class="post-grid">
            {{#foreach posts}}
                {{> post-card}}
            {{/foreach}}
        </div>
        {{pagination}}
    {{else}}
        <p class="empty-state">No posts by this author yet.</p>
    {{/if}}
</section>
